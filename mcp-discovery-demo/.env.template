# ────────────────────────────────────────────────────────────────────
# mcp-discovery-demo — Financial Analyst Toolkit
# Copy to .env and fill in (most values auto-detect from gcloud)
# ────────────────────────────────────────────────────────────────────

# === Auto-detected from gcloud config (override if needed) ===
PROJECT_ID=
PROJECT_NUMBER=
REGION=us-central1
REGISTRY_LOCATION=us-central1

# === Staging & resource names ===
# Defaults derive from PROJECT_ID — leave blank to use them.
STAGING_BUCKET=

# Cloud Run service names (also used as Agent Registry service names).
MARKET_MCP_SERVICE=fintoolkit-market-data-mcp
PORTFOLIO_MCP_SERVICE=fintoolkit-portfolio-mcp
NEWS_MCP_SERVICE=fintoolkit-news-sentiment-mcp

# Agent Registry display names (become tool prefix — keep short, snake_case).
MARKET_MCP_DISPLAY=market-data
PORTFOLIO_MCP_DISPLAY=portfolio
NEWS_MCP_DISPLAY=news-sentiment

# Orchestrator agent
ORCHESTRATOR_DISPLAY_NAME=fintoolkit-orchestrator

# === Model ===
GEMINI_MODEL=gemini-3-flash-preview

# === Local testing (used by local_test.py + `agents-cli run` against localhost MCPs) ===
MARKET_MCP_URL=http://localhost:8081/mcp
PORTFOLIO_MCP_URL=http://localhost:8082/mcp
NEWS_MCP_URL=http://localhost:8083/mcp
