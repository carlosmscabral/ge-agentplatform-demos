# === oauth-3lo-keycloak-demo — Environment Configuration ===
#
# Copy this file to .env and fill in the required values.
# All variables are auto-detected from gcloud where possible.

# === Required: GCP ===
# GCP project ID (auto-detected from `gcloud config get-value project` if unset)
PROJECT_ID=

# GCP region for Cloud Run services and Agent Runtime
REGION=us-central1

# Organization ID for SPIFFE principal set (auto-detected from `gcloud organizations list` if unset)
# ORG_ID=

# === Agent ===
AGENT_DISPLAY_NAME=oauth-3lo-agent
GEMINI_MODEL=gemini-3-flash-preview

# === Auth provider (Agent Identity Connector) ===
# Lowercase letters, digits, hyphens only; must start with a letter; cannot end with a hyphen.
AUTH_PROVIDER_NAME=oauth-3lo-keycloak
AUTH_PROVIDER_LOCATION=us-central1

# === Required: Keycloak (IdP) ===
# Base URL of the Keycloak server (no trailing slash).
KEYCLOAK_URL=

# Realm name (e.g., master, demo, production).
KEYCLOAK_REALM=

# Client registered in Keycloak for this demo.
# The redirect URI from `gcloud alpha agent-identity connectors describe` must be added
# to this client's Valid Redirect URIs BEFORE setting CLIENT_SECRET below.
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Audience claim ('aud') to validate in incoming JWTs.
# For Keycloak, this is typically the client ID or 'account' (if no audience mapper).
# If your client doesn't have an Audience Mapper configured, set to 'account' (Keycloak default).
KEYCLOAK_AUDIENCE=account

# Set to 'false' only to disable audience validation while debugging Keycloak client setup.
KEYCLOAK_VERIFY_AUDIENCE=true

# OAuth scopes to request from Keycloak. The Agent Identity Connector REQUIRES this
# to be set; if unset, the authorization request omits the `scope` parameter and
# Keycloak rejects with `invalid_scope`. The standard OIDC trio works for most setups.
ALLOWED_SCOPES=openid,profile,email

# === MCP server (Cloud Run) ===
MCP_SERVICE_NAME=oauth-3lo-mcp
MCP_REGISTRY_DISPLAY_NAME=oauth-3lo-mcp

# === Frontend (Cloud Run) ===
FRONTEND_SERVICE_NAME=oauth-3lo-frontend

# === Auto-derived (override if needed) ===
# GCS staging bucket for deployment artifacts and telemetry.
# STAGING_BUCKET=${PROJECT_ID}-oauth-3lo-staging

# === Gemini Enterprise Registration (optional — Rule #10) ===
# Set GEMINI_ENTERPRISE_APP_ID to register this agent with a GE App after deploy.
# Format: projects/<project>/locations/global/collections/default_collection/engines/<app-id>
# GEMINI_ENTERPRISE_APP_ID=
# GEMINI_DISPLAY_NAME=
# GEMINI_DESCRIPTION=
