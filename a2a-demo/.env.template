# === Google Cloud Project Settings ===
# Your GCP project ID (auto-detected from gcloud config if not set)
# PROJECT_ID=your-project-id

# GCP region for all resources
REGION=us-central1

# === Resource Names ===
SPECIALIST_DISPLAY_NAME=a2a-demo-specialist
ORCHESTRATOR_DISPLAY_NAME=a2a-demo-orchestrator

# Staging bucket (auto-derived from PROJECT_ID if not set)
# STAGING_BUCKET=your-project-id-a2a-demo-staging

# === Gemini Model ===
GEMINI_MODEL=gemini-3-flash-preview

# === A2A Configuration ===
# Specialist agent card URL (auto-populated by deploy.sh after specialist deploy)
# For local testing: http://localhost:8001/.well-known/agent.json
# SPECIALIST_A2A_CARD_URL=

# === Gemini Enterprise Registration (optional) ===
# Set GEMINI_ENTERPRISE_APP_ID to register this agent with a GE App after deploy.
# Format: projects/<project>/locations/global/collections/default_collection/engines/<app-id>
# GEMINI_ENTERPRISE_APP_ID=
# GEMINI_DISPLAY_NAME=
# GEMINI_DESCRIPTION=
# GE_AGENT_ID=  # Agent ID in GE (returned after registration, needed for undeploy)
