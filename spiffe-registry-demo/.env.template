# === spiffe-registry-demo — Environment Configuration ===

# === Required ===
# GCP project ID (auto-detected from gcloud if not set)
PROJECT_ID=

# GCP region for agent deployment
REGION=us-central1

# Gemini model for both agents
GEMINI_MODEL=gemini-3-flash-preview

# === Agent Names ===
SPECIALIST_DISPLAY_NAME=spiffe-specialist
ORCHESTRATOR_DISPLAY_NAME=spiffe-orchestrator

# === Auto-derived (override if needed) ===
# GCS staging bucket for deployment artifacts and telemetry
# STAGING_BUCKET=gs://${PROJECT_ID}-spiffe-registry-staging

# === Registry Discovery ===
# Agent Registry location for discovery queries
# Agents auto-register in the same region they're deployed to.
REGISTRY_LOCATION=us-central1

# === Fallback (optional) ===
# Primary discovery is via Agent Registry (AgentRegistry.get_remote_a2a_agent).
# Set this only if registry discovery fails — it bypasses registry and uses the URL directly.
# SPECIALIST_A2A_CARD_URL=

# === Gemini Enterprise Registration (optional) ===
# Set GEMINI_ENTERPRISE_APP_ID to register this agent with a GE App after deploy.
# Format: projects/<project>/locations/global/collections/default_collection/engines/<app-id>
# GEMINI_ENTERPRISE_APP_ID=
# GEMINI_DISPLAY_NAME=
# GEMINI_DESCRIPTION=
