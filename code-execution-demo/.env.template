# ────────────────────────────────────────────────────────────────────
# code-execution-demo — Data Analyst with Gemini built-in code execution
# Copy to .env and fill in (most values auto-detect from gcloud)
# ────────────────────────────────────────────────────────────────────

# === Auto-detected from gcloud config (override if needed) ===
PROJECT_ID=
PROJECT_NUMBER=
REGION=us-central1

# === Staging & resource names ===
# Default derives from PROJECT_ID — leave blank to use it.
STAGING_BUCKET=

# Display name visible in the Vertex AI Agent Engine console.
ORCHESTRATOR_DISPLAY_NAME=code-analyst

# === Model ===
# NOTE: this demo uses gemini-2.5-flash (the model the official ADK code-exec
# tutorial uses). Older Gemini-3-preview emitted code execution parts that
# bypassed our external sandbox — see LESSONS.md §12 for the investigation
# that led us to BuiltInCodeExecutor + gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
