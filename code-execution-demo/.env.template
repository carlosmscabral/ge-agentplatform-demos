# ────────────────────────────────────────────────────────────────────
# code-execution-demo — Data Analyst with Agent Engine Sandbox
# Copy to .env and fill in (most values auto-detect from gcloud)
# ────────────────────────────────────────────────────────────────────

# === Auto-detected from gcloud config (override if needed) ===
PROJECT_ID=
PROJECT_NUMBER=
REGION=us-central1

# === Staging & resource names ===
# Default derives from PROJECT_ID — leave blank to use it.
STAGING_BUCKET=

# Display names visible in the Vertex AI Agent Engine console.
ORCHESTRATOR_DISPLAY_NAME=code-analyst
SANDBOX_HOST_DISPLAY_NAME=code-analyst-sandbox-host
SANDBOX_DISPLAY_NAME=code-analyst-shared-sandbox

# === Sandbox lifecycle ===
# TTL of the pre-created shared sandbox. ADK's lazy-create path hardcodes
# ttl=1 year — we pre-create our own sandbox with a shorter TTL for
# lifecycle control. Default 86400s (24h). Examples: "3600s" (1h),
# "604800s" (7d).
#
# IMPORTANT: when this TTL expires, the agent's SANDBOX_RESOURCE_NAME env
# var points at a 404'd resource and `execute_code` calls will fail. To
# refresh: re-run `./deploy.sh` (idempotent — Step 5 detects the missing
# sandbox and creates a new one, then Step 6 redeploys the agent with the
# new resource name).
#
# Trade-off: shorter TTL = better cost governance, but more frequent
# redeploy. 24h is a reasonable demo default. See LESSONS.md §11.
SANDBOX_TTL=86400s

# === Model ===
GEMINI_MODEL=gemini-3-flash-preview

# NOTE: AGENT_ENGINE_RESOURCE_NAME is NOT set here — it is discovered or
# created by deploy.sh Step 4 (sandbox-host pre-create) and injected into
# the orchestrator's runtime env vars via --update-env-vars.
